NODE_ENV=development
HOST=127.0.0.1
PORT=8210
DATABASE_URL=mysql://efatura:efatura@127.0.0.1:3306/efatura_service
REDIS_URL=
WORKER_ENABLED=true
EFATURA_ENC_KEY=replace-with-32-byte-base64-or-hex-key
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
EFATURA_DEV_TENANT_API_KEY=
EFATURA_DEV_INTEGRATOR_CREDENTIALS={}
EFATURA_DEV_WEBHOOK_SECRET=
EFATURA_NILVERA_MOCK=false
EFATURA_PUBLIC_URL=http://127.0.0.1:8210
SYNC_STATUS_ENABLED=true
STATUS_SYNC_INTERVAL_MS=300000
STATUS_SYNC_BATCH_SIZE=50
EFATURA_CANCEL_WINDOW_DAYS=7
EFATURA_ADMIN_TOKEN=change-me-min-16-chars
