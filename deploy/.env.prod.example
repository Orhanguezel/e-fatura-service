# e-fatura-service prod .env (VPS /var/www/e-fatura-service/.env)
# SECRET — commit edilmez (.gitignore). docker-compose.prod.yml interpolasyonu + env_file.

# Compose servis şifreleri
MYSQL_PASSWORD=__32+_rastgele__
MYSQL_ROOT_PASSWORD=__32+_rastgele__

# Uygulama (DATABASE_URL/REDIS_URL/HOST/PORT/WORKER compose'da set edilir, buraya YAZMA)
EFATURA_ENC_KEY=__32_byte_base64_veya_hex__       # openssl rand -base64 32
EFATURA_ADMIN_TOKEN=__uzun_rastgele__              # admin API/panel
EFATURA_NILVERA_MOCK=true                          # sandbox credential gelene kadar true

# Dev tenant seed (db:seed:fresh için)
EFATURA_DEV_TENANT_API_KEY=__sportoonline_api_key__
EFATURA_DEV_WEBHOOK_SECRET=__sportoonline_webhook_secret_plaintext__
EFATURA_DEV_INTEGRATOR_CREDENTIALS={"api_key":"","base_url":"https://apitest.nilvera.com"}

# Opsiyonel ayarlar (varsayılanlar koddan)
RATE_LIMIT_MAX=100
STATUS_SYNC_CRON=*/15 * * * *
EFATURA_CANCEL_WINDOW_DAYS=7
